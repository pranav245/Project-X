# ─── VAPI ────────────────────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# ─── SARVAM AI ───────────────────────────────────────
SARVAM_API_KEY=
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_LID_URL=https://api.sarvam.ai/text-lid
SARVAM_DEFAULT_VOICE=meera

# ─── LLM (swap freely) ───────────────────────────────
# Providers: anthropic, openai, groq, together-ai, openrouter
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
LLM_API_KEY=

# Examples:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
#
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile

# ─── TELNYX ──────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=

# ─── DATABASE ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/projectsole

# ─── APP ─────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-random-32-char-string
BACKEND_URL=http://localhost:8000

# ─── SENTRY ──────────────────────────────────────────
SENTRY_DSN=
